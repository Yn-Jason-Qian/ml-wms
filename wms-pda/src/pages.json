    {
      "path": "pages/inbound/putaway/index",
      "style": {
        "navigationBarTitleText": "上架扫描"
      }
    },
    {
      "path": "pages/outbound/pick/index",
      "style": {
        "navigationBarTitleText": "拣货扫描"
      }
    },
    {
      "path": "pages/outbound/check/index",
      "style": {
